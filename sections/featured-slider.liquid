{{ 'featured-slider.css' | asset_url | stylesheet_tag }}

{% render 'featured-slider' %}


{%  schema  %} 
{
    "class": "featured-slider",
    "name": "Featured Slider",
    "tag": "section",
    "blocks": [
         {
            "type": "video_slider",
            "name":"Video Slider", 
            "settings": [

            {
                "type": "select",
                "options": [
                    {"value": "hosted","label": "Hosted"},
                    {"value": "youtubevimeo","label": "Youtube or vimeo"}
                ],
                "default":"hosted",
                "label": "Select video type",
                "id": "videotype"
            },
                {
                    "type": "video",
                    "id": "video",
                    "label": "Hosted Video",
                    "visible_if": "{{ block.settings.videotype == 'hosted' }}"
                },
                {
                    "type": "video_url",
                    "accept": ["vimeo","youtube"],
                    "id": "video_url",
                    "label": "Video",
                    "info": "Add link of Youtube or Vimeo",
                    "visible_if": "{{ block.settings.videotype == 'youtubevimeo' }}"
                },

                {
                    "type": "image_picker",
                    "id": "media",
                    "label": "Media"
                },
                {
                    "type": "image_picker",
                    "id": "media_phone",
                    "label": "Media"
                },

                {
                    "type": "text",
                    "label": "Sub Title",
                    "id": "subtitle",
                    "default":"VACATURE"
                },
                {
                    "type": "text",
                    "label": "Title",
                    "id": "title",
                    "default":"Wij zoeken een ervaren fietsmonteur!"
                },
                {
                    "type": "range",
                    "id": "title_max_width",
                    "label": "Max Width",
                    "min": 400,
                    "max": 1000,
                    "unit": "px",
                    "step": 10,
                    "default": 700 
                }, 
                {
                    "type": "textarea",
                    "label": "Content",
                    "id": "content",
                    "default":"Heb jij net zo’n passie voor fietsen als wij en heb je ervaring in het onderhouden, repareren en afstellen van diverse fietsen? Bekijk dan onze vacature en wie weet tot snel!"
                },
                {
                    "type": "range",
                    "id": "content_max_width",
                    "label": "Max Width",
                    "min": 400,
                    "max": 1000,
                    "unit": "px",
                    "step": 10,
                    "default": 500 
                }, 
                {
                    "type": "text",
                    "label": "Bottom Text",
                    "id": "bottomtext",
                    "default":"*Zolang de voorraad strekt"
                },
                {
                    "type": "text",
                    "id":"btn_text",
                    "label": "Button Text",
                    "default":"BEKIJK VACATURE"
                },
                {
                    "type": "url",
                    "label": "Button Link",
                    "id": "btn_url"
                },
                 
                {
                    "type": "color_scheme",
                    "id": "color_scheme",
                    "label": "Slide Color",
                    "default": "scheme-5"
                } 

            ]
        },
        {
            "type": "product_slider",
            "name":"Product Slider",
            "settings": [
                {
                    "type": "product",
                    "id": "product",
                    "label": "Select Product"
                },

                {
                    "type": "image_picker",
                    "id": "media",
                    "label": "Media" 
                },
                {
                    "type": "image_picker",
                    "id": "media_phone",
                    "label": "Media for Phone" 
                },

                {
                    "type": "text",
                    "label": "Sub Title",
                    "id": "subtitle",
                    "default":"VACATURE"
                },
                {
                    "type": "text",
                    "label": "Title",
                    "id": "title" 
                },
                {
                    "type": "range",
                    "id": "title_max_width",
                    "label": "Max Width",
                    "min": 400,
                    "max": 1000,
                    "unit": "px",
                    "step": 10,
                    "default": 700 
                }, 
                {
                    "type": "richtext",
                    "label": "Content",
                    "id": "content" 
                },
                {
                    "type": "range",
                    "id": "content_max_width",
                    "label": "Max Width",
                    "min": 400,
                    "max": 1000,
                    "unit": "px",
                    "step": 10,
                    "default": 500 
                }, 
                {
                    "type": "text",
                    "label": "Bottom Text",
                    "id": "bottomtext" 
                },
                {
                    "type": "text",
                    "id":"btn_text",
                    "label": "Button Text",
                    "default":"BEKIJK VACATURE"
                },
                {
                    "type": "url",
                    "label": "Button Link",
                    "id": "btn_url"
                },
                 
                {
                    "type": "checkbox",
                    "id":"badge",
                    "label": "Add Badge",
                    "default": false
                },
                {
                    "type": "image_picker",
                    "id": "badge_image",
                    "label": "Badge Image",
                    "visible_if": "{{ block.settings.badge == true }}"
                },
                {
                    "type": "inline_richtext",
                    "id": "badge_text",
                    "label": "Text",
                    "visible_if": "{{ block.settings.badge == true }}",
                    "default":"GRATIS KINDERZITJE + GOUD PAKKET T.W.V. €225"
                },
                {
                    "type": "range",
                    "id": "badge_width",
                    "label": "Badge Width",
                    "min": 0,
                    "max": 300,
                    "unit": "px",
                    "step": 4,
                    "default": 240,
                    "visible_if": "{{ block.settings.badge == true }}"
                }, 
                {
                    "type": "range",
                    "id": "vertical",
                    "label": "Vertical Position",
                    "min": 0,
                    "max": 100,
                    "unit": "%",
                    "step": 1,
                    "default": 100,
                    "visible_if": "{{ block.settings.badge == true }}"
                }, 
                {
                    "type": "range",
                    "id": "horizontal",
                    "label": "Horizontal Position",
                    "min": 0,
                    "max": 100,
                    "unit": "%",
                    "step": 1,
                    "default": 50,
                    "visible_if": "{{ block.settings.badge == true }}"
                }, 
                {
                    "type": "header",
                    "content":"Mobile Badge Style"
                },
                {
                    "type": "range",
                    "id": "badge_width_phone",
                    "label": "Badge Width",
                    "min": 0,
                    "max": 300,
                    "unit": "px",
                    "step": 4,
                    "default": 200,
                    "visible_if": "{{ block.settings.badge == true }}"
                }, 
                {
                    "type": "range",
                    "id": "vertical_phone",
                    "label": "Vertical Position",
                    "min": 0,
                    "max": 100,
                    "unit": "%",
                    "step": 1,
                    "default": 100,
                    "visible_if": "{{ block.settings.badge == true }}"
                }, 
                {
                    "type": "range",
                    "id": "horizontal_phone",
                    "label": "Horizontal Position",
                    "min": 0,
                    "max": 100,
                    "unit": "%",
                    "step": 1,
                    "default": 50,
                    "visible_if": "{{ block.settings.badge == true }}"
                }, 
                {
                    "type": "color_scheme",
                    "id": "color_scheme",
                    "label": "Slide Color",
                    "default": "scheme-5"
                } 

            ]
        },
