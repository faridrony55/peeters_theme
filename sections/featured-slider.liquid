{{ 'featured-slider.css' | asset_url | stylesheet_tag }}

{% render 'featured-slider' %}


<script>
    var swiper = new Swiper(".{{section.id}}", {
          slidesPerView: 1, 
          spaceBetween: 0,
        speed: 5000, 
        loop: true,
        autoplay: {
       delay: 0,
       disableOnInteraction: false, 
       } 

        

    });
  </script>

{%  schema  %} 
{
    "class": "featured-slider",
    "name": "Featured Slider",
    "tag": "section",
    "blocks": [
        {
            "type": "image_slider",
            "name":"Image Slider", 
            "settings": [

                {
                    "type": "image_picker",
                    "id": "media",
                    "label": "Media"
                },
                {
                    "type": "image_picker",
                    "id": "media_phone",
                    "label": "Media"
                },

                {
                    "type": "text",
                    "label": "Sub Title",
                    "id": "subtitle",
                    "default":"VACATURE"
                },
                {
                    "type": "text",
                    "label": "Title",
                    "id": "title",
                    "default":"Wij zoeken een ervaren fietsmonteur!"
                },
                {
                    "type": "textarea",
                    "label": "Content",
                    "id": "content",
                    "default":"Heb jij net zo’n passie voor fietsen als wij en heb je ervaring in het onderhouden, repareren en afstellen van diverse fietsen? Bekijk dan onze vacature en wie weet tot snel!"
                },
                {
                    "type": "text",
                    "id":"btn_text",
                    "label": "Button Text",
                    "default":"BEKIJK VACATURE"
                },
                {
                    "type": "url",
                    "label": "Button Link",
                    "id": "btn_url"
                },
                {
                    "type": "color_scheme",
                    "id": "color_scheme",
                    "label": "Slide Color",
                    "default": "scheme-5"
                } 

            ]
        }
    ],
    "settings": [
        {
            "type": "header",
            "content": "Section Style"
        },
        {
            "type": "text",
            "default":"1603px",
            "id": "layout_max_width",
            "label": "Layout Max Width" 
        },
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Section Color",
            "default": "scheme-5"
        },
        {
            "type": "range",
            "id": "padding_top",
            "label": "Padding Top",
            "min": 0,
            "max": 100,
            "unit": "px",
            "step": 1,
            "default": 20
        },

        {
            "type": "range",
            "id": "padding_bottom",
            "label": "Padding Bottom",
            "min": 0,
            "max": 100,
            "unit": "px",
            "step": 1,
            "default": 20
        }
    ],
    "presets": [
        {
            "name": "Featured Slider"
        }
    ]

}
{% endschema %}