
{% liquid 
    assign layout_max_width = section.settings.layout_max_width
    assign padding_top = section.settings.padding_top
    assign padding_bottom = section.settings.padding_bottom
    assign gap_horizontal =  section.settings.gap_horizontal
    assign gap_vertical =  section.settings.gap_vertical
    assign block_align = section.settings.block_align
%}


{%  style  %} 
    .advisor-section{
        --padding_top: {{padding_top}}px;
        --padding_bottom: {{padding_bottom}}px;
        --gap_horizontal : {{gap_horizontal}}px;
        --gap_vertical : {{gap_vertical}}px;
        --block_align: {{block_align}};
    }
    {% if layout_max_width != '' %}
        .advisor-section .page-width{
            max-width: {{layout_max_width}};
        }
    {% endif %}
{% endstyle %}  

<section class="color-{{ section.settings.color_scheme }} gradient">
    <div class="page-width">
  
        <div class="flex">
            {{ children }}
        </div>


    </div>
</section>